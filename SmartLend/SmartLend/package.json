    "react-scripts": "5.0.1",
    "recharts": "^3.6.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "tw:watch": "npx tailwindcss -i ./src/tailwind.css -o ./src/tailwind-output.css --watch",
    "tw:build": "npx tailwindcss -i ./src/tailwind.css -o ./src/tailwind-output.css",
    "start": "concurrently \"npm run tw:watch\" \"react-scripts start\"",
    "build": "npm run tw:build && react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19"
  }
